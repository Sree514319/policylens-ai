# =====================================================================
# PolicyLens AI - Environment Variables (example)
# Copy this file to ".env" and fill in real values. Never commit ".env".
# =====================================================================

# --- LLM Provider API Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LLM Model Selection ---
ANTHROPIC_MODEL=
OPENAI_MODEL=

# --- LLM / RAG Safety & Behavior ---
# Real Anthropic/OpenAI network calls are refused (safe config error, no
# network attempt) unless this is explicitly "true". Leave false for local
# development and demos.
ALLOW_EXTERNAL_LLM_CALLS=false
LLM_TIMEOUT_SECONDS=
LLM_MAX_OUTPUT_TOKENS=
LLM_MAX_RETRIES=
MAX_RAG_CONTEXT_CHARACTERS=

# --- Application Environment ---
APP_ENV=
LOG_LEVEL=

# --- Backend (FastAPI) ---
BACKEND_HOST=
BACKEND_PORT=

# --- Frontend (Streamlit) ---
STREAMLIT_SERVER_PORT=

# --- Vector Store (ChromaDB) ---
CHROMA_PERSIST_DIRECTORY=
CHROMA_COLLECTION_NAME=

# --- Vector Search / Retrieval ---
EMBEDDING_MODEL_NAME=
RETRIEVAL_TOP_K=
MIN_RELEVANCE_SCORE=

# --- Document Upload Constraints ---
MAX_UPLOAD_SIZE_MB=
ALLOWED_FILE_TYPES=

# --- Text Chunking ---
CHUNK_SIZE=
CHUNK_OVERLAP=
MIN_CHUNK_LENGTH=

# --- Privacy / PII Masking (local, regex-based -- no cloud PII service) ---
PII_PROTECTION_ENABLED=true
PII_MODE=mask
PII_REDACTION_VERSION=
PII_MASK_EMAILS=true
PII_MASK_PHONES=true
PII_MASK_FINANCIAL_IDENTIFIERS=true

# --- Observability / Metrics ---
ENABLE_COST_TRACKING=
ENABLE_LATENCY_TRACKING=

# --- Model Evaluation / Comparison (Phase 7) ---
# Optional USD price per 1,000,000 tokens, per provider. Leave blank to
# keep estimated_cost_usd null -- this project never hardcodes a vendor's
# current price list, since it changes over time and would go stale.
ANTHROPIC_INPUT_COST_PER_MILLION=
ANTHROPIC_OUTPUT_COST_PER_MILLION=
OPENAI_INPUT_COST_PER_MILLION=
OPENAI_OUTPUT_COST_PER_MILLION=
# Relative tie tolerance (fraction, 0-1) for /api/v1/compare's metric diffs.
MODEL_COMPARISON_TIE_THRESHOLD=
# Minimum term length counted as "meaningful" for grounded_term_ratio.
GROUNDED_TERM_MIN_LENGTH=

# --- Frontend (Streamlit) API Client (Phase 8) ---
# Base URL the Streamlit frontend uses to reach the FastAPI backend --
# never a place for API keys; the frontend talks to the backend over
# plain HTTP and never calls Anthropic/OpenAI directly.
POLICYLENS_API_BASE_URL=http://localhost:8000
# Request timeout (seconds) for the frontend's HTTP calls to the backend.
FRONTEND_REQUEST_TIMEOUT_SECONDS=30
