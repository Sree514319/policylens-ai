# =====================================================================
# PolicyLens AI - Environment Variables (example)
# Copy this file to ".env" and fill in real values. Never commit ".env".
# =====================================================================

# --- LLM Provider API Keys ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- LLM Model Selection ---
ANTHROPIC_MODEL=
OPENAI_MODEL=

# --- Application Environment ---
APP_ENV=
LOG_LEVEL=

# --- Backend (FastAPI) ---
BACKEND_HOST=
BACKEND_PORT=

# --- Frontend (Streamlit) ---
STREAMLIT_SERVER_PORT=

# --- Vector Store (ChromaDB) ---
CHROMA_PERSIST_DIRECTORY=
CHROMA_COLLECTION_NAME=

# --- Vector Search / Retrieval ---
EMBEDDING_MODEL_NAME=
RETRIEVAL_TOP_K=
MIN_RELEVANCE_SCORE=

# --- Document Upload Constraints ---
MAX_UPLOAD_SIZE_MB=
ALLOWED_FILE_TYPES=

# --- Text Chunking ---
CHUNK_SIZE=
CHUNK_OVERLAP=
MIN_CHUNK_LENGTH=

# --- Privacy / PII Masking ---
ENABLE_PII_MASKING=

# --- Observability / Metrics ---
ENABLE_COST_TRACKING=
ENABLE_LATENCY_TRACKING=
